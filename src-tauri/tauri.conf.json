{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lockbook",
  "version": "1.2.1",
  "identifier": "io.github.SnowTimSwiss.LockBook",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Lockbook",
        "width": 1200,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "copyright": "GPL-3.0",
    "shortDescription": "Encrypted personal journal powered by TimENC",
    "longDescription": "Lockbook is a secure encrypted diary that uses TimENC (ChaCha20-Poly1305 + Argon2id) to protect your entries."
  }
}
